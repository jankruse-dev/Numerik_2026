\newcommand{\maketitlepage}[1][fhblue]{

% \titlepage
% \begin{textblock*}{5cm}(7.5cm,0.5cm) % {Breite}(X-Koordinate, Y-Koordinate)
%     \includegraphics[width=5cm]{Vorlage/fhm_Logo_CMYK_17mm.pdf}
% \end{textblock*}

\begin{frame}[plain] % [plain] entfernt Kopf-/Fußzeile für das Deckblatt
    
    \begin{tikzpicture}[remember picture, overlay]
    
    % 1. Der untere, schraffierte Bereich
    \fill[pattern=north east lines, pattern color=#1] 
        ([xshift=0.4\paperwidth]current page.south west) rectangle ([yshift=0.55\paperheight]current page.south east);

    % 2. Die diagonalen blauen Balken (Parallelogramme)
    % Wir zeichnen sie von rechts oben nach unten
    \foreach \x in {0, 2, 3.6, 5.4, 7.2, 9, 10.8} {
        \fill[#1] 
            ([xshift=\x cm]current page.north) -- ++(0.5,0) -- ++(-6,-0.6\paperheight) -- ++(-0.5,0) -- cycle;
    }

    % 3. Die weißen Trenner / Hintergrund für die Balken
    % Wir legen eine weiße Fläche über die rechte Hälfte, um die linke sauber zu halten
    \fill[white] (current page.north west) rectangle ([xshift=0.6\paperwidth]current page.south west);

    % 4. Logo oben links
    \node[anchor=north west] at ([xshift=0.5cm, yshift=0cm]current page.north west) {
        \includegraphics[width=4cm]{fhm_Logo_CMYK_17mm.pdf} % Pfad anpassen!
    };

    \end{tikzpicture}

    % Textplatzierung 
    \begin{minipage}{0.40\paperwidth}
        \raggedright % Schaltet auf Linksbündig um
        \vspace{3em}
        \Large\textbf{\gettitle}\\
        \vspace{3.5cm} 
        \normalsize\getauthor\\
        \vspace{1em}
        \small\getdate  
    \end{minipage}

\end{frame}
}

